# ====== CONFIGURACIÓN DE BASE DE DATOS ======

# OPCIÓN 1: SQLite (desarrollo local)
DATABASE_URL=sqlite:///reportes.db

# OPCIÓN 2: PostgreSQL (RECOMENDADO para Render/producción)
# En Render: PostgreSQL → Settings → Internal Database URL
# Ejemplo: postgresql://user:pass@dpg-xxxxx.render.internal:5432/reportes
# DATABASE_URL=postgresql://user:password@localhost:5432/reportes

SQLALCHEMY_TRACK_MODIFICATIONS=False

# ====== CONFIGURACIÓN DE FLASK ======
FLASK_ENV=development
# Generar: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=tu_clave_secreta_aqui_cambiar_en_produccion

# ====== CARGA DE ARCHIVOS ======
MAX_CONTENT_LENGTH=50000000
UPLOAD_FOLDER=uploads/
ALLOWED_EXTENSIONS=xlsx

# ====== CONFIGURACIÓN DE CORREO ======
# Para Gmail: https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=contraseña_de_app_google

MAIL_DEFAULT_SENDER=noreply@empresa.com
MAIL_RECIPIENTS=admin@empresa.com

# ====== LOGGING ======
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
